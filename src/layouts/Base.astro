---
import '../styles/global.css';
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Sirius Ganesh — Deployment Engineering · Warehouse Robotics',
  description = 'Sirius Ganesh — Deployment engineering leader scaling warehouse robotics from startup pilot to enterprise production. Pickle Robot · Geek+ · AMR fleets · systems integration.',
} = Astro.props;
const today = new Date();
const docDate = `${today.getFullYear()}.${String(today.getMonth()+1).padStart(2,'0')}.${String(today.getDate()).padStart(2,'0')}`;

// Normalised current path used to mark the active project in the projects
// dropdown. Astro's static build serves directory indexes, so the pathname
// for the coffee page is "/coffee/". Strip the trailing slash for clean
// equality checks. The dropdown only contains /coffee from the apex domain;
// the other items live on github.io and can never match the current Astro
// page, so we only need an isCoffee flag here.
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isCoffee = currentPath === '/coffee';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://siriusganesh.com/" />
    <meta property="og:image" content="https://siriusganesh.com/og-image.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://siriusganesh.com/og-image.jpg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/favicon.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link
      rel="preload"
      as="image"
      href="/images/sirius-wife-hero.webp"
      imagesrcset="/images/sirius-wife-hero-mobile.webp 400w, /images/sirius-wife-hero-400w.webp 600w, /images/sirius-wife-hero.webp 1200w"
      imagesizes="(max-width: 560px) 180px, (max-width: 720px) 220px, 300px"
      fetchpriority="high"
    />
    <link rel="preload" as="font" type="font/woff2" href="/fonts/ibm-plex-mono-400.woff2" crossorigin />
    <title>{title}</title>
  </head>
  <body>
    <nav class="topnav">
      <div class="wrap">
        <a href="https://siriusganesh.com/" class="brand">sirius ganesh</a>
        <ul>
          <li class="has-dropdown">
            <details>
              <summary>projects</summary>
              <ul class="dropdown-menu">
                <li>
                  <a
                    href="/coffee"
                    class:list={[isCoffee && 'is-current']}
                    aria-current={isCoffee ? 'page' : undefined}
                    aria-disabled={isCoffee ? 'true' : undefined}
                    tabindex={isCoffee ? -1 : undefined}
                  >coffee</a>
                </li>
                <li>
                  <a href="https://siriusganesh.github.io/co-14ers/" target="_blank" rel="noopener">
                    colorado 14ers <span class="ext-arrow" aria-hidden="true">↗</span>
                  </a>
                </li>
                <li>
                  <a href="https://siriusganesh.github.io/bananagrams-checker/" target="_blank" rel="noopener">
                    bananagrams <span class="ext-arrow" aria-hidden="true">↗</span>
                  </a>
                </li>
              </ul>
            </details>
          </li>
        </ul>
      </div>
    </nav>
    <main class="page">
      <slot />
    </main>
    <footer class="page-footer">
      <span>{docDate}</span>
      <span>sirius ganesh · denver, co</span>
      <span>v1.0</span>
    </footer>

    <script>
      // For any topnav link (brand or section link) whose pathname matches the
      // current page and has no hash, intercept and smooth-scroll to top
      // instead of triggering a full reload. Cross-page links (e.g. /coffee
      // from /, or /#experience from /coffee) are left to navigate normally.
      // Hash-only links to sections on the current page are also left alone —
      // CSS scroll-behavior on html handles those smoothly.
      // Astro's static build serves pages as directory indexes, so the
      // browser's pathname is "/coffee/" while the link href resolves to
      // "/coffee". Strip any trailing slash before comparing so they match.
      const samePath = (a: string, b: string) =>
        a.replace(/\/$/, '') === b.replace(/\/$/, '');

      document.querySelectorAll('nav.topnav a').forEach((link) => {
        link.addEventListener('click', (event) => {
          const a = event.currentTarget as HTMLAnchorElement;
          const target = new URL(a.href);
          if (samePath(target.pathname, window.location.pathname) && !target.hash) {
            event.preventDefault();
            const reduced = window.matchMedia(
              '(prefers-reduced-motion: reduce)'
            ).matches;
            window.scrollTo({ top: 0, behavior: reduced ? 'auto' : 'smooth' });
          }
          // Collapse any open <details> dropdown after a nav link click so the
          // menu doesn't linger when navigating away or scrolling to top.
          const details = a.closest('nav.topnav details');
          if (details instanceof HTMLDetailsElement) details.open = false;
        });
      });

      // Close the projects dropdown on outside click or Escape.
      document.addEventListener('click', (event) => {
        document.querySelectorAll('nav.topnav details[open]').forEach((d) => {
          if (!(d as HTMLElement).contains(event.target as Node)) {
            (d as HTMLDetailsElement).open = false;
          }
        });
      });
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          document.querySelectorAll('nav.topnav details[open]').forEach((d) => {
            (d as HTMLDetailsElement).open = false;
          });
        }
      });
    </script>
  </body>
</html>
