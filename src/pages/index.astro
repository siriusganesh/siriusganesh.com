---
import Base from '../layouts/Base.astro';
import {
  profile,
  ledeHtml,
  heroPortrait,
  experience,
  educationBanner,
  school,
  research,
  capabilities,
  press,
  aboutParagraphsHtml,
  aboutGallery,
  contactHtml,
} from '../data/content';
---
<Base>
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-text">
        <span class="overline">{profile.overline}</span>
        <h1>{profile.name}<span class="accent">.</span></h1>
        <p class="lede" set:html={ledeHtml}></p>

        <div class="meta-row">
          <span class="pin">{profile.location}</span>
          <span class="pin"><a href={`mailto:${profile.email}`}>{profile.email}</a></span>
          <span class="pin"><a href={profile.linkedin} target="_blank" rel="noreferrer">linkedin</a></span>
          <span class="pin"><a href={profile.github} target="_blank" rel="noreferrer">github</a></span>
          <span class="pin"><a href={profile.resumeUrl} target="_blank" rel="noreferrer">resume</a></span>
        </div>
      </div>
      <figure class="hero-portrait">
        <img
          src={heroPortrait.src}
          srcset="/images/sirius-wife-hero-400w.webp 600w, /images/sirius-wife-hero.webp 1200w"
          sizes="(max-width: 560px) 180px, (max-width: 720px) 220px, 300px"
          alt={heroPortrait.alt}
          loading="eager"
          fetchpriority="high"
          decoding="sync"
        />
      </figure>
    </div>
  </section>

  <hr class="rule" />

  <section class="block" id="experience">
    <header>
      <h2>Experience</h2>
      <span class="meta">2021 — present</span>
    </header>

    {experience.map((job) => (
      <div class="experience-item">
        {job.image && (
          <div class="experience-image">
            <img
              src={job.image.src}
              srcset={job.image.srcset}
              sizes={job.image.sizes}
              alt={job.image.alt}
              loading="lazy"
              decoding="async"
            />
          </div>
        )}
        <div>
          <span class="role">{job.role}</span> ·
          <span class="org">{job.org} · {job.location}</span>
        </div>
        <span class="when">{job.when}</span>
        <ul>
          {job.bulletsHtml.map((b) => <li set:html={b}></li>)}
        </ul>
      </div>
    ))}
  </section>

  <section class="block" id="capabilities">
    <header>
      <h2>Capabilities</h2>
      <span class="meta">what I do</span>
    </header>

    <div class="capability-grid">
      {capabilities.map((group) => (
        <div>
          <h3>{group.title}</h3>
          <ul>
            {group.items.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="block" id="press">
    <header>
      <h2>Press &amp; case studies</h2>
      <span class="meta">external coverage</span>
    </header>

    {press.map((p) => (
      <article class="press-card">
        {p.image && (
          <div class="project-image">
            <img src={p.image.src} alt={p.image.alt} loading="lazy" decoding="async" />
          </div>
        )}
        <h3>
          {p.href ? (
            <a href={p.href} target="_blank" rel="noreferrer">
              {p.title} <span class="ext-arrow" aria-hidden="true">↗</span>
            </a>
          ) : (
            p.title
          )}
        </h3>
        <p set:html={p.descriptionHtml}></p>
        <div class="stack">{p.metaLine}</div>
      </article>
    ))}
  </section>

  <section class="block" id="education">
    <header>
      <h2>Education &amp; research</h2>
      <span class="meta">{school.when}</span>
    </header>

    <figure class="edu-banner">
      <img
        src={educationBanner.src}
        srcset={educationBanner.srcset}
        sizes={educationBanner.sizes}
        alt={educationBanner.alt}
        loading="lazy"
        decoding="async"
      />
    </figure>

    <div class="school-block">
      <div class="school-head">
        <div>
          <span class="school-name">{school.name}</span>
          <div class="school-degree">{school.degree}</div>
          <div class="school-detail">{school.detail}</div>
        </div>
        <span class="when">{school.when}</span>
      </div>
      <ul class="school-highlights">
        {school.highlightsHtml.map((h) => <li set:html={h}></li>)}
      </ul>
    </div>

    <h3 class="subsection-label">Research</h3>
    {research.slice(0, 1).map((r) => (
      <div class="research-item">
        <div class="research-head">
          <span class="research-title">{r.title}</span>
          <span class="when">{r.when}</span>
        </div>
        <p set:html={r.descriptionHtml}></p>
        <div class="stack">{r.citation}</div>
      </div>
    ))}

    {research.length > 1 && (
      <details class="research-more">
        <summary>
          <span class="more-label">Show {research.length - 1} more</span>
          <span class="less-label">Show less</span>
        </summary>
        {research.slice(1).map((r) => (
          <div class="research-item">
            <div class="research-head">
              <span class="research-title">{r.title}</span>
              <span class="when">{r.when}</span>
            </div>
            <p set:html={r.descriptionHtml}></p>
            <div class="stack">{r.citation}</div>
          </div>
        ))}
      </details>
    )}
  </section>

  <section class="block" id="about">
    <header>
      <h2>About</h2>
      <span class="meta">off the clock</span>
    </header>
    <div class="about-text">
      {aboutParagraphsHtml.map((p) => <p set:html={p}></p>)}
    </div>
    <div class="about-gallery">
      {aboutGallery.map((tile) => (
        tile.kind === "photo" ? (
          <figure class="about-tile photo">
            <img src={tile.src} alt={tile.alt} loading="lazy" decoding="async" />
            <figcaption>
              <span class="tile-label">{tile.label}</span>
              <span class="tile-caption">{tile.caption}</span>
            </figcaption>
          </figure>
        ) : (
          <div class="about-tile text">
            <span class="tile-label">{tile.label}</span>
            <span class="tile-headline">{tile.headline}</span>
            <span class="tile-caption">{tile.caption}</span>
          </div>
        )
      ))}
    </div>
  </section>

  <section class="block" id="contact">
    <header>
      <h2>Contact</h2>
    </header>
    <p set:html={contactHtml}></p>
  </section>
</Base>
