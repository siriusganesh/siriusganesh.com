---
import Base from '../layouts/Base.astro';
import {
  brews,
  activeBeans,
  bags,
  pastBeans,
  comingSoonBeans,
  rig,
  bagBadges,
  bagIdOf,
  daysBetween,
  flowRate,
  ratio,
} from '../data/coffee';

// Reverse-chronological log for display: newest dates first, and within a single
// date the later-submitted shot ranks above the earlier one (the source array is
// append-only, so reversing the array gives both at once). Keep the original
// chronological order under `chrono` for chart math / day-off-roast derivations.
const chrono = [...brews];
const newestFirst = [...brews].reverse();

// Today string (used for "days since open" on currently-brewing bags)
const today = new Date().toISOString().slice(0, 10);

// ---------- CHART ----------
// Axes:
//   x = days off roast at time of brew
//   y = flow rate (g/s) = yieldG / timeS
//
// Three layers, back to front:
//   1. Individual shots — clean shots as hollow dashed rings; tainted shots
//      (entry.flag set) as small × markers in the bean's color. Both show
//      within-day variation; the × also signals "excluded from the math".
//   2. Per-day mean of *clean* shots (solid dot). Tainted shots are not
//      counted in this mean; days that are entirely tainted have no dot.
//   3. Log-fit degradation line per bean (y = a + b·ln(x+1)), fit by closed-
//      form OLS on the clean shots only. Skipped for beans with <3 clean
//      shots or <3 distinct clean days off roast.

type Point = {
  x: number;        // days off roast
  y: number;        // flow rate g/s
  grind: string;
  entry: typeof chrono[number];
  tainted: boolean; // entry.flag set → excluded from daily mean + regression
};

type DayPoint = {
  x: number;        // days off roast (shared across shots on that day)
  y: number;        // mean flow rate for that day (clean shots only)
  count: number;    // number of clean shots averaged
  date: string;
};

// Lookup by bagId for legends, titles, and color resolution.
const bagsByBagId = new Map(bags.map((b) => [bagIdOf(b), b]));

// Group individual shots by bagId (was: by bean). Keying off bagId lets two
// bags that share a bean name (e.g. a repurchased Mokha Java with a newer
// roast date) render as separate series instead of conflating.
const rawByBagId = new Map<string, Point[]>();
for (const e of chrono) {
  const id = bagIdOf(e);
  const p: Point = {
    x: daysBetween(e.date, e.roastDate),
    y: flowRate(e),
    grind: e.grind ?? '',
    entry: e,
    tainted: !!e.flag,
  };
  const list = rawByBagId.get(id) ?? [];
  list.push(p);
  rawByBagId.set(id, list);
}

// Collapse to one point per (bagId, date) using mean flow rate of CLEAN shots
// only. Days that have only tainted shots produce no DayPoint — those shots
// still render as × markers but don't contribute a daily mean dot.
const avgByBagId = new Map<string, DayPoint[]>();
for (const [id, shots] of rawByBagId.entries()) {
  const byDate = new Map<string, Point[]>();
  for (const p of shots) {
    if (p.tainted) continue;
    const key = p.entry.date;
    const list = byDate.get(key) ?? [];
    list.push(p);
    byDate.set(key, list);
  }
  const days: DayPoint[] = [];
  for (const [date, dayShots] of byDate.entries()) {
    const meanY = dayShots.reduce((s, p) => s + p.y, 0) / dayShots.length;
    days.push({ x: dayShots[0].x, y: meanY, count: dayShots.length, date });
  }
  days.sort((a, b) => a.x - b.x);
  avgByBagId.set(id, days);
}

// Per-cohort degradation fit: y = a + b·ln(x + 1), via closed-form OLS on the
// transformed regressor u = ln(x + 1). Right shape for the 5–30-day window
// where outgassing is still rising (fast early, slowing toward a plateau)
// without a 3-parameter nonlinear fit. Computed from clean shots only.
//
// A "cohort" is (bagId, grind). Splitting by grind avoids confounding the
// degradation fit when the user changes grind setting mid-bag: a finer grind
// shifts the absolute flow-rate baseline, which would otherwise look like
// (or mask) a real outgassing change. Each cohort gets its own curve.
//
// Cohorts with <3 clean shots or <3 distinct clean days off roast get no fit
// (their dots still render — the chart just doesn't draw a curve through too
// little data).
type Fit = { a: number; b: number };
function cohortKey(bagId: string, grind: string): string {
  return `${bagId}::${grind}`;
}
// Group shots by cohort and track first-shot date per cohort so cohorts on
// the same bag can be ordered chronologically for stroke-style assignment.
const cohortShots = new Map<string, Point[]>();
const cohortFirstDate = new Map<string, string>();
for (const [bagId, shots] of rawByBagId.entries()) {
  for (const p of shots) {
    const c = cohortKey(bagId, p.grind);
    const list = cohortShots.get(c) ?? [];
    list.push(p);
    cohortShots.set(c, list);
    const prev = cohortFirstDate.get(c);
    if (!prev || p.entry.date < prev) cohortFirstDate.set(c, p.entry.date);
  }
}
const fitByCohortId = new Map<string, Fit>();
for (const [cohortId, shots] of cohortShots.entries()) {
  const clean = shots.filter((p) => !p.tainted);
  const distinctDays = new Set(clean.map((p) => p.x));
  if (clean.length < 3 || distinctDays.size < 3) continue;
  const n = clean.length;
  let sU = 0, sY = 0, sUU = 0, sUY = 0;
  for (const p of clean) {
    const u = Math.log(p.x + 1);
    sU += u;
    sY += p.y;
    sUU += u * u;
    sUY += u * p.y;
  }
  const denom = n * sUU - sU * sU;
  if (Math.abs(denom) < 1e-12) continue;  // x's collapsed; no fit
  const b = (n * sUY - sU * sY) / denom;
  const a = (sY - b * sU) / n;
  fitByCohortId.set(cohortId, { a, b });
}

// Chart geometry
const W = 640;
const H = 280;
const M = { top: 20, right: 20, bottom: 36, left: 44 };
const innerW = W - M.left - M.right;
const innerH = H - M.top - M.bottom;

// Axis domains. Pad so points don't sit on the edges.
// Domain uses raw shots so ghost dots at the extremes still fit on the canvas.
// x: 0 -> max days off roast observed, rounded up to next 5, min 30
const allX = [...rawByBagId.values()].flat().map((p) => p.x);
const allY = [...rawByBagId.values()].flat().map((p) => p.y);
const xMaxData = allX.length ? Math.max(...allX) : 30;
const xMax = Math.max(30, Math.ceil(xMaxData / 5) * 5);
const xMin = 0;
// y: flow rates land ~1.0 - 2.5 g/s typically. Widen a bit either side of data.
const yMinData = allY.length ? Math.min(...allY) : 1.0;
const yMaxData = allY.length ? Math.max(...allY) : 2.0;
const yMin = Math.max(0, Math.floor((yMinData - 0.3) * 10) / 10);
const yMax = Math.ceil((yMaxData + 0.3) * 10) / 10;

function sx(x: number): number {
  return M.left + ((x - xMin) / (xMax - xMin)) * innerW;
}
function sy(y: number): number {
  // invert: high y value -> low pixel
  return M.top + innerH - ((y - yMin) / (yMax - yMin)) * innerH;
}

// Peak-window shading (espresso rule of thumb: 7 - 21 days off roast).
const peakX1 = sx(7);
const peakX2 = sx(21);

// X-axis ticks every 5 days
const xTicks: number[] = [];
for (let t = 0; t <= xMax; t += 5) xTicks.push(t);

// Y-axis ticks every 0.25 g/s
const yTicks: number[] = [];
for (let t = Math.ceil(yMin / 0.25) * 0.25; t <= yMax + 1e-9; t += 0.25) {
  yTicks.push(Number(t.toFixed(2)));
}

// Per-bag chart color. Prefer the bag's explicit `chartColor` (chosen to
// match the bag's packaging) so each bag reads the same on the chart, on the
// legend, and on the dot in the bean card. Fall back to a cycled palette if
// a bag hasn't set one yet, or if a brew references a bagId without a
// matching Bag entry (orphan brews).
const palette = ['#011f5b', '#990000', '#2a6', '#c70', '#73c'];
const bagColor = new Map<string, string>();
[...rawByBagId.keys()].forEach((id, i) => {
  const explicit = bagsByBagId.get(id)?.chartColor;
  bagColor.set(id, explicit ?? palette[i % palette.length]);
});

// Pre-compute fit polylines per cohort, grouped by bag for the render loop.
// One <polyline> per fitted cohort. Cohort index within a bag (in chronological
// order of first shot) drives stroke-dasharray so multiple cohorts on the same
// bag stay visually distinct: solid (0), dashed (1), dotted (2+).
// Per-cohort polyline keeps DOM cost flat (one element per cohort's fit, not 40).
const FIT_SAMPLES = 40;
const DASH_BY_INDEX: Array<string | undefined> = [undefined, '5 4', '1 3'];
type CohortFit = { path: string; dashArray: string | undefined; grind: string };
const fitsByBagId = new Map<string, CohortFit[]>();
for (const bagId of rawByBagId.keys()) {
  // Cohorts for this bag, ordered chronologically by first-shot date.
  const cohortsForBag = [...cohortShots.entries()]
    .filter(([cId]) => cId.startsWith(`${bagId}::`))
    .sort((a, b) =>
      (cohortFirstDate.get(a[0]) ?? '').localeCompare(cohortFirstDate.get(b[0]) ?? '')
    );
  const fits: CohortFit[] = [];
  cohortsForBag.forEach(([cohortId, shots], idx) => {
    const fit = fitByCohortId.get(cohortId);
    if (!fit) return;
    const cleanXs = shots.filter((p) => !p.tainted).map((p) => p.x);
    if (cleanXs.length === 0) return;
    const xLo = Math.max(xMin, Math.min(...cleanXs));
    const xHi = Math.min(xMax, Math.max(...cleanXs));
    if (xHi <= xLo) return;
    const pts: string[] = [];
    for (let i = 0; i <= FIT_SAMPLES; i++) {
      const xi = xLo + ((xHi - xLo) * i) / FIT_SAMPLES;
      const yi = fit.a + fit.b * Math.log(xi + 1);
      pts.push(`${sx(xi).toFixed(1)},${sy(yi).toFixed(1)}`);
    }
    fits.push({
      path: pts.join(' '),
      dashArray: DASH_BY_INDEX[idx] ?? '1 3',
      grind: shots[0]?.grind ?? '',
    });
  });
  if (fits.length > 0) fitsByBagId.set(bagId, fits);
}

// ---------- BAG PICKER ----------
// Build the dropdown's options in three optgroups, in this order:
//   1. Coming soon  (bought, not yet opened)
//   2. Open         (default-selected)
//   3. Past         (finished)
// Visual order ≠ default selection — defaultBagId still resolves to the open bag.
// Option values use bagId (slug(bean)-roastDate) so repeat purchases of the
// same bean don't collide; option labels still read `bean · roastDate`.
const openBags = [...activeBeans].sort((a, b) =>
  (b.openedDate ?? '').localeCompare(a.openedDate ?? '')
);
const comingSoonBags = [...comingSoonBeans].sort((a, b) =>
  b.roastDate.localeCompare(a.roastDate)
);
const closedBags = [...pastBeans].sort((a, b) =>
  (b.closedDate ?? '').localeCompare(a.closedDate ?? '')
);
const defaultBagId =
  (openBags[0] && bagIdOf(openBags[0])) ??
  (comingSoonBags[0] && bagIdOf(comingSoonBags[0])) ??
  (closedBags[0] && bagIdOf(closedBags[0])) ??
  '';

// Per-bag shot counts. Used for the Log header meta text — updated client-side
// when the dropdown changes. Stashed on the section element as a data attribute
// so the script can read it without another round-trip.
const shotsByBagId: Record<string, number> = {};
for (const e of brews) {
  const id = bagIdOf(e);
  shotsByBagId[id] = (shotsByBagId[id] ?? 0) + 1;
}
const shotsByBagIdJSON = JSON.stringify(shotsByBagId);

// Per-bag log rows, in display order (newest first within each bag). Each
// entry carries its original index in `brews` so the notes-detail row id stays
// unique across templates and survives reordering.
//
// Only the default-selected bag's rows render directly into the table on SSR.
// The remaining bags' rows live in <template> elements; their content is in an
// inert document fragment and is NOT counted toward Lighthouse's DOM-size audit.
// The bag-picker script clones the matching template into the table on change.
type IndexedBrew = { e: typeof brews[number]; i: number };
const newestFirstByBagId = new Map<string, IndexedBrew[]>();
brews.forEach((e, i) => {
  const id = bagIdOf(e);
  const list = newestFirstByBagId.get(id) ?? [];
  list.push({ e, i });
  newestFirstByBagId.set(id, list);
});
// Source array is append-only chronological, so reversing each per-bag list
// gives newest-first AND later-submitted-first within the same date.
for (const list of newestFirstByBagId.values()) list.reverse();

const defaultRows = newestFirstByBagId.get(defaultBagId) ?? [];
const nonDefaultRowsByBagId = [...newestFirstByBagId.entries()].filter(
  ([id]) => id !== defaultBagId
);
---
<Base
  title="coffee lab · sirius ganesh"
  description="Espresso brew log and bean-degradation chart for Sirius Ganesh's home setup (Lelit Mara X + DF64)."
>
  <section class="hero coffee-hero">
    <div class="hero-text">
      <span class="overline">coffee lab</span>
      <h1>brew log<span class="accent">.</span></h1>
      <p class="lede">
        Personal espresso journal. Tracking beans against days off roast to see
        when they fall off peak. Pulled on <strong>{rig.machine}</strong>
        ground with <strong>{rig.grinder}</strong>. Time measured from first
        drop to end of pour.
      </p>
    </div>
  </section>

  <hr class="rule" />

  <section class="block bag-picker-block" id="bag-picker" aria-label="Bag selector">
    <label class="bag-picker-label" for="bag-select">Viewing</label>
    <select
      class="bag-picker"
      id="bag-select"
      aria-controls="bag-scoped"
    >
      {comingSoonBags.length > 0 && (
        <optgroup label="Coming soon">
          {comingSoonBags.map((b) => {
            const id = bagIdOf(b);
            return (
              <option value={id} selected={id === defaultBagId}>
                {b.bean} · {b.roastDate}
              </option>
            );
          })}
        </optgroup>
      )}
      {openBags.length > 0 && (
        <optgroup label="Open">
          {openBags.map((b) => {
            const id = bagIdOf(b);
            return (
              <option value={id} selected={id === defaultBagId}>
                {b.bean} · {b.roastDate}
              </option>
            );
          })}
        </optgroup>
      )}
      {closedBags.length > 0 && (
        <optgroup label="Past">
          {closedBags.map((b) => {
            const id = bagIdOf(b);
            return (
              <option value={id} selected={id === defaultBagId}>
                {b.bean} · {b.roastDate}
              </option>
            );
          })}
        </optgroup>
      )}
    </select>
  </section>

  <div id="bag-scoped" data-selected-bag-id={defaultBagId} data-shots-by-bag-id={shotsByBagIdJSON}>

  <section class="block" id="bag-info">
    <div class="bean-grid">
      {bags.map((b) => {
        const id = bagIdOf(b);
        return (
        // SSR-hide non-default bean cards so first paint matches the post-script
        // state. Otherwise the grid lays out as 3+1 on desktop, then the picker
        // script hides 3 cards and the remaining card snaps from row1-col3 to
        // row1-col1 (and the chart below slides up) — a single LayoutShift that
        // scored ~0.091 on desktop run 1. JS toggle uses style.display, so
        // matching that here (inline style) lets removeProperty/'display'='none'
        // continue to work on dropdown change.
        <div class="bean-card" data-bag-id={id} style={id === defaultBagId ? undefined : 'display:none'}>
          <div class="bean-name">{b.bean}</div>
          {b.roaster && <div class="bean-roaster">{b.roaster}</div>}
          {(() => {
            const badges = bagBadges(b);
            return badges.length > 0 ? (
              <div class="bean-badges">{badges.join(' · ')}</div>
            ) : null;
          })()}
          {b.origin && <div class="bean-origin">{b.origin}</div>}
          {b.tastingNotes && b.tastingNotes.length > 0 && (
            <div class="bean-notes">{b.tastingNotes.join(' · ')}</div>
          )}
          {/* Optional single-origin detail block. Each row only renders when
              the field is set, so blends and minimal entries collapse cleanly. */}
          {(b.producer || b.elevation || (b.varieties && b.varieties.length > 0) || b.harvest) && (
            <table class="bean-details">
              {b.producer && (
                <tr><td>producer</td><td>{b.producer}</td></tr>
              )}
              {b.elevation && (
                <tr><td>elevation</td><td>{b.elevation}</td></tr>
              )}
              {b.varieties && b.varieties.length > 0 && (
                <tr><td>varieties</td><td>{b.varieties.join(', ')}</td></tr>
              )}
              {b.harvest && (
                <tr><td>harvest</td><td>{b.harvest}</td></tr>
              )}
            </table>
          )}
          {/* Bag age/lifecycle line. Three states:
              - Past  (closedDate set): roasted X · open Y → Z
              - Coming soon (no openedDate, no closedDate): roasted X (not yet opened)
              - Open  (openedDate, no closedDate): Nd off roast */}
          {b.closedDate ? (
            <div class="bean-age">
              roasted {b.roastDate}
              {b.openedDate && ` · open ${b.openedDate} → ${b.closedDate}`}
            </div>
          ) : !b.openedDate ? (
            <div class="bean-age">roasted {b.roastDate} · not yet opened</div>
          ) : (
            <div class="bean-age">{daysBetween(today, b.roastDate)}d off roast</div>
          )}
        </div>
        );
      })}
    </div>
  </section>

  <section class="block" id="degradation">
    <header>
      <h2>Degradation</h2>
      <span class="meta">flow rate vs days off roast</span>
    </header>

    <figure class="chart">
      <svg viewBox={`0 0 ${W} ${H}`} width={W} height={H} xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Flow rate vs days off roast">
        {/* peak-window shaded band */}
        <rect
          x={peakX1}
          y={M.top}
          width={peakX2 - peakX1}
          height={innerH}
          fill="#dbe3f5"
          opacity="0.45"
        />
        <text
          x={(peakX1 + peakX2) / 2}
          y={M.top + 12}
          text-anchor="middle"
          font-size="10"
          fill="#616160"
          font-family="IBM Plex Mono, monospace"
        >
          peak window
        </text>

        {/* gridlines + x-axis ticks */}
        {xTicks.map((t) => (
          <g>
            <line
              x1={sx(t)} y1={M.top}
              x2={sx(t)} y2={M.top + innerH}
              stroke="#e4e4df"
              stroke-width="1"
            />
            <text
              x={sx(t)}
              y={M.top + innerH + 16}
              text-anchor="middle"
              font-size="10"
              fill="#616160"
              font-family="IBM Plex Mono, monospace"
            >{t}</text>
          </g>
        ))}

        {/* y-axis ticks */}
        {yTicks.map((t) => (
          <g>
            <line
              x1={M.left} y1={sy(t)}
              x2={M.left + innerW} y2={sy(t)}
              stroke="#e4e4df"
              stroke-width="1"
            />
            <text
              x={M.left - 6}
              y={sy(t) + 3}
              text-anchor="end"
              font-size="10"
              fill="#616160"
              font-family="IBM Plex Mono, monospace"
            >{t.toFixed(2)}</text>
          </g>
        ))}

        {/* axis labels */}
        <text
          x={M.left + innerW / 2}
          y={H - 4}
          text-anchor="middle"
          font-size="10"
          fill="#303130"
          font-family="IBM Plex Mono, monospace"
          letter-spacing="0.05em"
        >DAYS OFF ROAST</text>
        <text
          x={-H / 2}
          y={12}
          transform="rotate(-90)"
          text-anchor="middle"
          font-size="10"
          fill="#303130"
          font-family="IBM Plex Mono, monospace"
          letter-spacing="0.05em"
        >FLOW RATE (g/s)</text>

        {/* axes */}
        <line x1={M.left} y1={M.top + innerH} x2={M.left + innerW} y2={M.top + innerH} stroke="#91928f" stroke-width="1" />
        <line x1={M.left} y1={M.top} x2={M.left} y2={M.top + innerH} stroke="#91928f" stroke-width="1" />

        {/* Individual shots, back layer. Clean shots → hollow dashed ring.
            Tainted shots → small × marker in the bag's color (still on the
            chart, but the title says why it's excluded). */}
        {[...rawByBagId.entries()].map(([id, points]) => {
          const color = bagColor.get(id) ?? '#011f5b';
          const label = bagsByBagId.get(id)
            ? `${bagsByBagId.get(id)!.bean} · ${bagsByBagId.get(id)!.roastDate}`
            : id;
          return (
            <g data-bag-id={id}>
              {points.map((p) => {
                const cx = sx(p.x);
                const cy = sy(p.y);
                if (p.tainted) {
                  const r = 3.5;
                  const d =
                    `M${(cx - r).toFixed(1)},${(cy - r).toFixed(1)} ` +
                    `L${(cx + r).toFixed(1)},${(cy + r).toFixed(1)} ` +
                    `M${(cx - r).toFixed(1)},${(cy + r).toFixed(1)} ` +
                    `L${(cx + r).toFixed(1)},${(cy - r).toFixed(1)}`;
                  return (
                    <path
                      d={d}
                      fill="none"
                      stroke={color}
                      stroke-width="1.1"
                      stroke-opacity="0.7"
                      stroke-linecap="round"
                    >
                      <title>{`${p.entry.date} · ${label} · ${p.x}d off · ${p.y.toFixed(2)} g/s · ${p.grind} (excluded: ${p.entry.flag})`}</title>
                    </path>
                  );
                }
                return (
                  <circle
                    cx={cx} cy={cy} r="3"
                    fill="none"
                    stroke={color}
                    stroke-width="1"
                    stroke-opacity="0.55"
                    stroke-dasharray="2 1.5"
                  >
                    <title>{`${p.entry.date} · ${label} · ${p.x}d off · ${p.y.toFixed(2)} g/s · ${p.grind} (raw shot)`}</title>
                  </circle>
                );
              })}
            </g>
          );
        })}

        {/* Primary series: log-fit degradation curve + per-day mean dots
            (clean shots only). Fit is computed in the frontmatter. */}
        {[...avgByBagId.entries()].map(([id, days]) => {
          const color = bagColor.get(id) ?? '#011f5b';
          const cohortFits = fitsByBagId.get(id) ?? [];
          const label = bagsByBagId.get(id)
            ? `${bagsByBagId.get(id)!.bean} · ${bagsByBagId.get(id)!.roastDate}`
            : id;
          return (
            <g data-bag-id={id}>
              {cohortFits.map((cf) => (
                <polyline
                  points={cf.path}
                  fill="none"
                  stroke={color}
                  stroke-width="0.8"
                  stroke-opacity="0.65"
                  stroke-dasharray={cf.dashArray}
                >
                  <title>{`${label} · ${cf.grind} fit`}</title>
                </polyline>
              ))}
              {days.map((d) => (
                <circle cx={sx(d.x)} cy={sy(d.y)} r="4" fill={color}>
                  <title>{`${d.date} · ${label} · ${d.x}d off · ${d.y.toFixed(2)} g/s (mean of ${d.count} clean shot${d.count === 1 ? '' : 's'})`}</title>
                </circle>
              ))}
            </g>
          );
        })}
      </svg>

      <figcaption class="chart-legend">
        {[...rawByBagId.keys()].map((id) => {
          const b = bagsByBagId.get(id);
          const label = b ? `${b.bean} · ${b.roastDate}` : id;
          return (
            <span class="legend-item" data-bag-id={id}>
              <span class="legend-dot" style={`background:${bagColor.get(id)}`}></span>
              {label}
            </span>
          );
        })}
        <span class="legend-item legend-note">
          <span class="legend-dot legend-dot-solid"></span>daily mean
          <span class="legend-dot legend-dot-ghost"></span>individual shot
          <span class="legend-x" aria-hidden="true">×</span>excluded
        </span>
      </figcaption>
    </figure>

    <p class="chart-note">
      Higher flow = less puck resistance. Rising trend at the same grind
      suggests beans losing CO<sub>2</sub>. Each curve is a logarithmic fit
      (y = a + b·ln(x + 1)) on clean shots only; it captures the fast-early,
      slowing degradation shape without overfitting the handful of data
      points per bag. Fits are computed per grind setting — bags brewed
      with multiple grinds get one curve per grind, distinguished by stroke
      style (solid, then dashed, then dotted in the order each grind was
      first used). Solid dots are per-day averages of clean shots, hollow
      dashed rings are individual clean shots, and
      <span aria-hidden="true">×</span> marks shots excluded from the math
      (dial-in sweeps, prep mistakes, or process errors — hover for the
      reason). Shaded band is the rough espresso peak window
      (7 – 21 days off roast).
    </p>
  </section>

  <section class="block" id="log">
    <header>
      <h2>Log</h2>
      <span class="meta" id="log-shot-count">{shotsByBagId[defaultBagId] ?? 0} shots</span>
    </header>

    <div class="log-table-wrap">
      <table class="log-table">
        <thead>
          <tr>
            <th scope="col">date</th>
            <th scope="col">off&nbsp;roast</th>
            <th scope="col">bean</th>
            <th scope="col">dose</th>
            <th scope="col">yield</th>
            <th scope="col">ratio</th>
            <th scope="col">time</th>
            <th scope="col">flow</th>
            <th scope="col">grind</th>
            <th scope="col">notes</th>
          </tr>
        </thead>
        <tbody>
          {/* Empty-state row per bag with no brews yet. Tagged with data-bag-id
              so it inherits the same show/hide filter as real rows. */}
          {bags.filter((b) => (shotsByBagId[bagIdOf(b)] ?? 0) === 0).map((b) => (
            <tr class="log-row log-empty" data-bag-id={bagIdOf(b)}>
              <td colspan="10" class="log-empty-cell">No shots logged yet for this bag.</td>
            </tr>
          ))}
          {/* Only the default-selected bag's rows render in the table at SSR.
              Other bags' rows live in <template> elements after the table and
              get swapped in by the bag-picker script. This keeps the initial DOM
              small for Lighthouse without changing the visible UX. */}
          {defaultRows.map(({ e, i }) => (
            <>
              <tr class="log-row" data-bag-id={bagIdOf(e)}>
                <td>{e.date}</td>
                <td>{daysBetween(e.date, e.roastDate)}d</td>
                <td>{e.bean}</td>
                <td>{e.doseG.toFixed(1)}g</td>
                <td>{e.yieldG.toFixed(1)}g</td>
                <td>{ratio(e)}</td>
                <td>{e.timeS}s</td>
                <td>{flowRate(e).toFixed(2)}</td>
                <td>{e.grind ?? '—'}</td>
                <td class="notes-cell">
                  {e.notes && (
                    <button
                      type="button"
                      class="notes-toggle"
                      aria-expanded="false"
                      aria-controls={`brew-note-${i}`}
                      aria-label="Show notes"
                    >
                      <svg viewBox="0 0 10 10" width="10" height="10" aria-hidden="true" focusable="false">
                        <polyline points="3.5,1.5 6.5,5 3.5,8.5"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="1.4"
                                  stroke-linecap="round"
                                  stroke-linejoin="round" />
                      </svg>
                    </button>
                  )}
                </td>
              </tr>
              {e.notes && (
                <tr class="notes-detail" id={`brew-note-${i}`} data-bag-id={bagIdOf(e)} hidden>
                  <td colspan="10" class="notes-detail-cell">{e.notes}</td>
                </tr>
              )}
            </>
          ))}
        </tbody>
      </table>
    </div>

    {/* Inert <template> fragments — one per non-default bag. Content is in a
        document fragment, NOT in the main document tree, so it does not count
        toward Lighthouse's DOM-size audit. The bag-picker script clones the
        matching template's content into the table tbody on selection change. */}
    {nonDefaultRowsByBagId.map(([id, rows]) => (
      <template data-brews-template={id}>
        {rows.map(({ e, i }) => (
          <>
            <tr class="log-row" data-bag-id={bagIdOf(e)}>
              <td>{e.date}</td>
              <td>{daysBetween(e.date, e.roastDate)}d</td>
              <td>{e.bean}</td>
              <td>{e.doseG.toFixed(1)}g</td>
              <td>{e.yieldG.toFixed(1)}g</td>
              <td>{ratio(e)}</td>
              <td>{e.timeS}s</td>
              <td>{flowRate(e).toFixed(2)}</td>
              <td>{e.grind ?? '—'}</td>
              <td class="notes-cell">
                {e.notes && (
                  <button
                    type="button"
                    class="notes-toggle"
                    aria-expanded="false"
                    aria-controls={`brew-note-${i}`}
                    aria-label="Show notes"
                  >
                    <svg viewBox="0 0 10 10" width="10" height="10" aria-hidden="true" focusable="false">
                      <polyline points="3.5,1.5 6.5,5 3.5,8.5"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.4"
                                stroke-linecap="round"
                                stroke-linejoin="round" />
                    </svg>
                  </button>
                )}
              </td>
            </tr>
            {e.notes && (
              <tr class="notes-detail" id={`brew-note-${i}`} data-bag-id={bagIdOf(e)} hidden>
                <td colspan="10" class="notes-detail-cell">{e.notes}</td>
              </tr>
            )}
          </>
        ))}
      </template>
    ))}
  </section>

  </div>

  <script>
    // Notes column disclosure pattern. Each row with notes has a chevron button
    // that toggles a sibling .notes-detail row. Only one detail row may be open
    // at a time across the table.
    document.addEventListener('click', (event) => {
      const target = event.target as Element | null;
      const btn = target?.closest?.('.notes-toggle') as HTMLButtonElement | null;
      if (!btn) return;
      const row = btn.closest('tr');
      const detail = row?.nextElementSibling as HTMLElement | null;
      if (!detail || !detail.classList.contains('notes-detail')) return;

      const opening = detail.hasAttribute('hidden');

      // Collapse any other open detail rows in the same table.
      const table = row?.closest('table');
      table?.querySelectorAll('.notes-detail').forEach((other) => {
        const el = other as HTMLElement;
        if (el !== detail && !el.hasAttribute('hidden')) {
          el.setAttribute('hidden', '');
          const otherBtn = el.previousElementSibling?.querySelector('.notes-toggle');
          otherBtn?.setAttribute('aria-expanded', 'false');
        }
      });

      if (opening) {
        detail.removeAttribute('hidden');
        btn.setAttribute('aria-expanded', 'true');
        // Mobile: when opening a row while the table is horizontally scrolled,
        // bring the wrap back to scrollLeft=0 so the detail row starts on screen
        // rather than mid-sentence.
        const wrap = table?.parentElement as HTMLElement | null;
        if (wrap?.classList.contains('log-table-wrap') && wrap.scrollLeft > 0) {
          wrap.scrollTo({ left: 0, behavior: 'smooth' });
        }
      } else {
        detail.setAttribute('hidden', '');
        btn.setAttribute('aria-expanded', 'false');
      }
    });

    // Bag picker: hide chart elements, legend items, bean cards, and empty-state
    // log rows whose data-bag-id does not match the selected option. Log content
    // rows are NOT in the static DOM for non-default bags — they live in
    // <template> elements and get cloned into the table only when needed. This
    // keeps the initial DOM small for Lighthouse.
    //
    // Also updates the Log section's shot-count meta text. Filter is applied on
    // load (so the default-selected bag is correct even if the script runs
    // after first paint) and again on every change.
    (() => {
      const select = document.getElementById('bag-select') as HTMLSelectElement | null;
      const scope = document.getElementById('bag-scoped');
      const countEl = document.getElementById('log-shot-count');
      if (!select || !scope) return;

      let counts: Record<string, number> = {};
      try {
        counts = JSON.parse(scope.dataset.shotsByBagId ?? '{}');
      } catch { counts = {}; }

      // Log-table swap: capture the SSR'd default-bag rows once so we can
      // restore them when the user picks the default bag again. Non-default
      // bags' rows come from <template data-brews-template="…"> fragments.
      const tbody = scope.querySelector('.log-table tbody') as HTMLElement | null;
      const defaultBagId = scope.getAttribute('data-selected-bag-id') ?? '';
      const logRowSelector = 'tr.log-row:not(.log-empty), tr.notes-detail';
      let initialDefaultRowsHTML: string | null = null;
      if (tbody) {
        initialDefaultRowsHTML = [...tbody.querySelectorAll(logRowSelector)]
          .map((r) => (r as HTMLElement).outerHTML)
          .join('');
      }
      let currentBagId = defaultBagId;

      function setLogRows(bagId: string) {
        if (!tbody || bagId === currentBagId) return;
        // Remove existing content rows (keep empty-state rows in place; those
        // are toggled separately by the [data-bag-id] display loop below).
        tbody.querySelectorAll(logRowSelector).forEach((el) => el.remove());
        let html = '';
        if (bagId === defaultBagId) {
          html = initialDefaultRowsHTML ?? '';
        } else {
          const tpl = document.querySelector(
            `template[data-brews-template="${CSS.escape(bagId)}"]`
          ) as HTMLTemplateElement | null;
          html = tpl?.innerHTML ?? '';
        }
        if (html) tbody.insertAdjacentHTML('beforeend', html);
        currentBagId = bagId;
      }

      function applyFilter(bagId: string) {
        scope!.setAttribute('data-selected-bag-id', bagId);

        // Swap log content rows first so the [data-bag-id] loop below sees the
        // newly-inserted rows for the selected bag (they're all matches, so
        // the loop becomes a no-op for them — but it still hides empty-state
        // rows for non-selected bags).
        setLogRows(bagId);

        // Toggle every data-bag-id element inside the scope.
        scope!.querySelectorAll<HTMLElement>('[data-bag-id]').forEach((el) => {
          const match = el.getAttribute('data-bag-id') === bagId;
          if (match) {
            el.style.removeProperty('display');
          } else {
            el.style.display = 'none';
            // If we just hid an open notes-detail row, collapse it so it
            // doesn't pop open silently when the user switches back.
            if (el.classList.contains('notes-detail') && !el.hasAttribute('hidden')) {
              el.setAttribute('hidden', '');
              const prev = el.previousElementSibling;
              prev?.querySelector('.notes-toggle')?.setAttribute('aria-expanded', 'false');
            }
          }
        });

        if (countEl) {
          const n = counts[bagId] ?? 0;
          countEl.textContent = `${n} shot${n === 1 ? '' : 's'}`;
        }
      }

      // Smooth-scroll target on user-initiated change. Picker section is
      // intentional: keeps the dropdown in view (handy on mobile if the user
      // wants to flip bags again) and the bag card lands right below it.
      // Honors prefers-reduced-motion. The initial applyFilter on page load
      // does not scroll — that path runs before the change listener is wired.
      const prefersReducedMotion = window.matchMedia(
        '(prefers-reduced-motion: reduce)'
      ).matches;
      const scrollTarget = document.getElementById('bag-picker');

      select.addEventListener('change', () => {
        applyFilter(select.value);
        scrollTarget?.scrollIntoView({
          behavior: prefersReducedMotion ? 'auto' : 'smooth',
          block: 'start',
        });
      });
      applyFilter(select.value);
    })();
  </script>
</Base>
