---
import Base from '../layouts/Base.astro';
import {
  brews,
  activeBeans,
  bags,
  pastBeans,
  rig,
  daysBetween,
  flowRate,
  ratio,
} from '../data/coffee';

// Sort log newest-first for display. Keep original chronological order for chart math.
const chrono = [...brews];
const newestFirst = [...brews].sort((a, b) =>
  (b.date + b.bean).localeCompare(a.date + a.bean)
);

// Today string (used for "days since open" on currently-brewing bags)
const today = new Date().toISOString().slice(0, 10);

// ---------- CHART ----------
// Axes:
//   x = days off roast at time of brew
//   y = flow rate (g/s) = yieldG / timeS
//
// Primary series: per-day MEAN flow rate per bean. Line connects these.
// Ghost series: individual shots (hollow dots) shown behind the mean points
//               so daily variation is visible without cluttering the line.

type Point = {
  x: number;        // days off roast
  y: number;        // flow rate g/s
  grind: string;
  entry: typeof chrono[number];
};

type DayPoint = {
  x: number;        // days off roast (shared across shots on that day)
  y: number;        // mean flow rate for that day
  count: number;    // number of shots averaged
  date: string;
};

// Group individual shots by bean (used as ghost dots)
const rawByBean = new Map<string, Point[]>();
for (const e of chrono) {
  const p: Point = {
    x: daysBetween(e.date, e.roastDate),
    y: flowRate(e),
    grind: e.grind ?? '',
    entry: e,
  };
  const list = rawByBean.get(e.bean) ?? [];
  list.push(p);
  rawByBean.set(e.bean, list);
}

// Collapse to one point per (bean, date) using mean flow rate (used as line + solid dots)
const avgByBean = new Map<string, DayPoint[]>();
for (const [bean, shots] of rawByBean.entries()) {
  const byDate = new Map<string, Point[]>();
  for (const p of shots) {
    const key = p.entry.date;
    const list = byDate.get(key) ?? [];
    list.push(p);
    byDate.set(key, list);
  }
  const days: DayPoint[] = [];
  for (const [date, dayShots] of byDate.entries()) {
    const meanY = dayShots.reduce((s, p) => s + p.y, 0) / dayShots.length;
    days.push({ x: dayShots[0].x, y: meanY, count: dayShots.length, date });
  }
  days.sort((a, b) => a.x - b.x);
  avgByBean.set(bean, days);
}

// Chart geometry
const W = 640;
const H = 280;
const M = { top: 20, right: 20, bottom: 36, left: 44 };
const innerW = W - M.left - M.right;
const innerH = H - M.top - M.bottom;

// Axis domains. Pad so points don't sit on the edges.
// Domain uses raw shots so ghost dots at the extremes still fit on the canvas.
// x: 0 -> max days off roast observed, rounded up to next 5, min 30
const allX = [...rawByBean.values()].flat().map((p) => p.x);
const allY = [...rawByBean.values()].flat().map((p) => p.y);
const xMaxData = allX.length ? Math.max(...allX) : 30;
const xMax = Math.max(30, Math.ceil(xMaxData / 5) * 5);
const xMin = 0;
// y: flow rates land ~1.0 - 2.5 g/s typically. Widen a bit either side of data.
const yMinData = allY.length ? Math.min(...allY) : 1.0;
const yMaxData = allY.length ? Math.max(...allY) : 2.0;
const yMin = Math.max(0, Math.floor((yMinData - 0.3) * 10) / 10);
const yMax = Math.ceil((yMaxData + 0.3) * 10) / 10;

function sx(x: number): number {
  return M.left + ((x - xMin) / (xMax - xMin)) * innerW;
}
function sy(y: number): number {
  // invert: high y value -> low pixel
  return M.top + innerH - ((y - yMin) / (yMax - yMin)) * innerH;
}

// Peak-window shading (espresso rule of thumb: 7 - 21 days off roast).
const peakX1 = sx(7);
const peakX2 = sx(21);

// X-axis ticks every 5 days
const xTicks: number[] = [];
for (let t = 0; t <= xMax; t += 5) xTicks.push(t);

// Y-axis ticks every 0.25 g/s
const yTicks: number[] = [];
for (let t = Math.ceil(yMin / 0.25) * 0.25; t <= yMax + 1e-9; t += 0.25) {
  yTicks.push(Number(t.toFixed(2)));
}

// Color palette cycled per bean
const palette = ['#011f5b', '#a33', '#2a6', '#c70', '#73c'];
const beanColor = new Map<string, string>();
[...rawByBean.keys()].forEach((b, i) => beanColor.set(b, palette[i % palette.length]));

// ---------- BAG PICKER ----------
// Build the dropdown's options. Open bags first, then past bags, with an
// optgroup separator so they're visually distinct. Default-selected bag is
// the first open bag (newest open, by openedDate descending) — this is the
// one whose chart and log rows render visible on first paint.
const openBags = [...activeBeans].sort((a, b) =>
  (b.openedDate ?? '').localeCompare(a.openedDate ?? '')
);
const closedBags = [...pastBeans].sort((a, b) =>
  (b.closedDate ?? '').localeCompare(a.closedDate ?? '')
);
const defaultBean = openBags[0]?.bean ?? closedBags[0]?.bean ?? '';

// Per-bean shot counts. Used for the Log header meta text — updated client-side
// when the dropdown changes. Stashed on the section element as a data attribute
// so the script can read it without another round-trip.
const shotsByBean: Record<string, number> = {};
for (const e of brews) {
  shotsByBean[e.bean] = (shotsByBean[e.bean] ?? 0) + 1;
}
const shotsByBeanJSON = JSON.stringify(shotsByBean);
---
<Base
  title="coffee lab · sirius ganesh"
  description="Espresso brew log and bean-degradation chart for Sirius Ganesh's home setup (Lelit Mara X + DF64)."
>
  <section class="hero coffee-hero">
    <div class="hero-text">
      <span class="overline">coffee lab</span>
      <h1>brew log<span class="accent">.</span></h1>
      <p class="lede">
        Personal espresso journal. Tracking beans against days off roast to see
        when they fall off peak. Pulled on <strong>{rig.machine}</strong>
        ground with <strong>{rig.grinder}</strong>. Time measured from first
        drop to end of pour.
      </p>
    </div>
  </section>

  <hr class="rule" />

  <section class="block" id="currently-brewing">
    <header>
      <h2>Currently brewing</h2>
      <span class="meta">{activeBeans.length} open</span>
    </header>
    <div class="bean-grid">
      {activeBeans.map((b) => (
        <div class="bean-card">
          <div class="bean-name">{b.bean}</div>
          {b.roaster && <div class="bean-roaster">{b.roaster}</div>}
          {b.badges && b.badges.length > 0 && (
            <div class="bean-badges">{b.badges.join(' · ')}</div>
          )}
          {b.origin && <div class="bean-origin">{b.origin}</div>}
          {b.tastingNotes && b.tastingNotes.length > 0 && (
            <div class="bean-notes">{b.tastingNotes.join(' · ')}</div>
          )}
          <div class="bean-age">{daysBetween(today, b.roastDate)}d off roast</div>
        </div>
      ))}
    </div>
  </section>

  <section class="block bag-picker-block" id="bag-picker" aria-label="Bag selector">
    <label class="bag-picker-label" for="bag-select">Viewing</label>
    <select
      class="bag-picker"
      id="bag-select"
      aria-controls="bag-scoped"
    >
      {openBags.length > 0 && (
        <optgroup label="Open">
          {openBags.map((b) => (
            <option value={b.bean} selected={b.bean === defaultBean}>
              {b.bean}{b.roaster ? ` · ${b.roaster}` : ''}
            </option>
          ))}
        </optgroup>
      )}
      {closedBags.length > 0 && (
        <optgroup label="Past">
          {closedBags.map((b) => (
            <option value={b.bean} selected={b.bean === defaultBean}>
              {b.bean}{b.roaster ? ` · ${b.roaster}` : ''}
            </option>
          ))}
        </optgroup>
      )}
    </select>
  </section>

  <div id="bag-scoped" data-selected-bean={defaultBean} data-shots-by-bean={shotsByBeanJSON}>

  <section class="block" id="degradation">
    <header>
      <h2>Degradation</h2>
      <span class="meta">flow rate vs days off roast</span>
    </header>

    <figure class="chart">
      <svg viewBox={`0 0 ${W} ${H}`} xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Flow rate vs days off roast">
        {/* peak-window shaded band */}
        <rect
          x={peakX1}
          y={M.top}
          width={peakX2 - peakX1}
          height={innerH}
          fill="#dbe3f5"
          opacity="0.45"
        />
        <text
          x={(peakX1 + peakX2) / 2}
          y={M.top + 12}
          text-anchor="middle"
          font-size="10"
          fill="#616160"
          font-family="IBM Plex Mono, monospace"
        >
          peak window
        </text>

        {/* gridlines + x-axis ticks */}
        {xTicks.map((t) => (
          <g>
            <line
              x1={sx(t)} y1={M.top}
              x2={sx(t)} y2={M.top + innerH}
              stroke="#e4e4df"
              stroke-width="1"
            />
            <text
              x={sx(t)}
              y={M.top + innerH + 16}
              text-anchor="middle"
              font-size="10"
              fill="#616160"
              font-family="IBM Plex Mono, monospace"
            >{t}</text>
          </g>
        ))}

        {/* y-axis ticks */}
        {yTicks.map((t) => (
          <g>
            <line
              x1={M.left} y1={sy(t)}
              x2={M.left + innerW} y2={sy(t)}
              stroke="#e4e4df"
              stroke-width="1"
            />
            <text
              x={M.left - 6}
              y={sy(t) + 3}
              text-anchor="end"
              font-size="10"
              fill="#616160"
              font-family="IBM Plex Mono, monospace"
            >{t.toFixed(2)}</text>
          </g>
        ))}

        {/* axis labels */}
        <text
          x={M.left + innerW / 2}
          y={H - 4}
          text-anchor="middle"
          font-size="10"
          fill="#303130"
          font-family="IBM Plex Mono, monospace"
          letter-spacing="0.05em"
        >DAYS OFF ROAST</text>
        <text
          x={-H / 2}
          y={12}
          transform="rotate(-90)"
          text-anchor="middle"
          font-size="10"
          fill="#303130"
          font-family="IBM Plex Mono, monospace"
          letter-spacing="0.05em"
        >FLOW RATE (g/s)</text>

        {/* axes */}
        <line x1={M.left} y1={M.top + innerH} x2={M.left + innerW} y2={M.top + innerH} stroke="#91928f" stroke-width="1" />
        <line x1={M.left} y1={M.top} x2={M.left} y2={M.top + innerH} stroke="#91928f" stroke-width="1" />

        {/* Ghost dots: individual shots, rendered behind so they show variation */}
        {[...rawByBean.entries()].map(([bean, points]) => {
          const color = beanColor.get(bean) ?? '#011f5b';
          return (
            <g data-bean={bean}>
              {points.map((p) => (
                <circle
                  cx={sx(p.x)} cy={sy(p.y)} r="3"
                  fill="none"
                  stroke={color}
                  stroke-width="1"
                  stroke-opacity="0.55"
                  stroke-dasharray="2 1.5"
                >
                  <title>{`${p.entry.date} · ${bean} · ${p.x}d off · ${p.y.toFixed(2)} g/s · ${p.grind} (raw shot)`}</title>
                </circle>
              ))}
            </g>
          );
        })}

        {/* Primary series: per-day mean flow rate — line + solid dots */}
        {[...avgByBean.entries()].map(([bean, days]) => {
          const color = beanColor.get(bean) ?? '#011f5b';
          const path = days.map((d) => `${sx(d.x).toFixed(1)},${sy(d.y).toFixed(1)}`).join(' ');
          return (
            <g data-bean={bean}>
              {days.length > 1 && (
                <polyline
                  points={path}
                  fill="none"
                  stroke={color}
                  stroke-width="1.5"
                  stroke-opacity="0.75"
                />
              )}
              {days.map((d) => (
                <circle cx={sx(d.x)} cy={sy(d.y)} r="4" fill={color}>
                  <title>{`${d.date} · ${bean} · ${d.x}d off · ${d.y.toFixed(2)} g/s (mean of ${d.count} shot${d.count === 1 ? '' : 's'})`}</title>
                </circle>
              ))}
            </g>
          );
        })}
      </svg>

      <figcaption class="chart-legend">
        {[...rawByBean.keys()].map((bean) => (
          <span class="legend-item" data-bean={bean}>
            <span class="legend-dot" style={`background:${beanColor.get(bean)}`}></span>
            {bean}
          </span>
        ))}
        <span class="legend-item legend-note">
          <span class="legend-dot legend-dot-solid"></span>daily mean
          <span class="legend-dot legend-dot-ghost"></span>individual shot
        </span>
      </figcaption>
    </figure>

    <p class="chart-note">
      Higher flow = less puck resistance. Rising trend at the same grind
      suggests beans losing CO<sub>2</sub>. Solid dots are per-day averages
      (connected by line); hollow dashed rings are individual shots, shown to
      expose within-day variation. Shaded band is the rough espresso peak
      window (7 – 21 days off roast).
    </p>
  </section>

  <section class="block" id="log">
    <header>
      <h2>Log</h2>
      <span class="meta" id="log-shot-count">{shotsByBean[defaultBean] ?? 0} shots</span>
    </header>

    <div class="log-table-wrap">
      <table class="log-table">
        <thead>
          <tr>
            <th scope="col">date</th>
            <th scope="col">off&nbsp;roast</th>
            <th scope="col">bean</th>
            <th scope="col">dose</th>
            <th scope="col">yield</th>
            <th scope="col">ratio</th>
            <th scope="col">time</th>
            <th scope="col">flow</th>
            <th scope="col">grind</th>
            <th scope="col">notes</th>
          </tr>
        </thead>
        <tbody>
          {/* Empty-state row per bag with no brews yet. Tagged with data-bean
              so it inherits the same show/hide filter as real rows. */}
          {bags.filter((b) => (shotsByBean[b.bean] ?? 0) === 0).map((b) => (
            <tr class="log-row log-empty" data-bean={b.bean}>
              <td colspan="10" class="log-empty-cell">No shots logged yet for this bag.</td>
            </tr>
          ))}
          {newestFirst.map((e, i) => (
            <>
              <tr class="log-row" data-bean={e.bean}>
                <td>{e.date}</td>
                <td>{daysBetween(e.date, e.roastDate)}d</td>
                <td>{e.bean}</td>
                <td>{e.doseG.toFixed(1)}g</td>
                <td>{e.yieldG.toFixed(1)}g</td>
                <td>{ratio(e)}</td>
                <td>{e.timeS}s</td>
                <td>{flowRate(e).toFixed(2)}</td>
                <td>{e.grind ?? '—'}</td>
                <td class="notes-cell">
                  {e.notes && (
                    <button
                      type="button"
                      class="notes-toggle"
                      aria-expanded="false"
                      aria-controls={`brew-note-${i}`}
                      aria-label="Show notes"
                    >
                      <svg viewBox="0 0 10 10" width="10" height="10" aria-hidden="true" focusable="false">
                        <polyline points="3.5,1.5 6.5,5 3.5,8.5"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="1.4"
                                  stroke-linecap="round"
                                  stroke-linejoin="round" />
                      </svg>
                    </button>
                  )}
                </td>
              </tr>
              {e.notes && (
                <tr class="notes-detail" id={`brew-note-${i}`} data-bean={e.bean} hidden>
                  <td colspan="10" class="notes-detail-cell">{e.notes}</td>
                </tr>
              )}
            </>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  </div>

  <script>
    // Notes column disclosure pattern. Each row with notes has a chevron button
    // that toggles a sibling .notes-detail row. Only one detail row may be open
    // at a time across the table.
    document.addEventListener('click', (event) => {
      const target = event.target as Element | null;
      const btn = target?.closest?.('.notes-toggle') as HTMLButtonElement | null;
      if (!btn) return;
      const row = btn.closest('tr');
      const detail = row?.nextElementSibling as HTMLElement | null;
      if (!detail || !detail.classList.contains('notes-detail')) return;

      const opening = detail.hasAttribute('hidden');

      // Collapse any other open detail rows in the same table.
      const table = row?.closest('table');
      table?.querySelectorAll('.notes-detail').forEach((other) => {
        const el = other as HTMLElement;
        if (el !== detail && !el.hasAttribute('hidden')) {
          el.setAttribute('hidden', '');
          const otherBtn = el.previousElementSibling?.querySelector('.notes-toggle');
          otherBtn?.setAttribute('aria-expanded', 'false');
        }
      });

      if (opening) {
        detail.removeAttribute('hidden');
        btn.setAttribute('aria-expanded', 'true');
        // Mobile: when opening a row while the table is horizontally scrolled,
        // bring the wrap back to scrollLeft=0 so the detail row starts on screen
        // rather than mid-sentence.
        const wrap = table?.parentElement as HTMLElement | null;
        if (wrap?.classList.contains('log-table-wrap') && wrap.scrollLeft > 0) {
          wrap.scrollTo({ left: 0, behavior: 'smooth' });
        }
      } else {
        detail.setAttribute('hidden', '');
        btn.setAttribute('aria-expanded', 'false');
      }
    });

    // Bag picker: hide chart elements, legend items, and log rows whose
    // data-bean does not match the selected option. Also updates the Log
    // section's shot-count meta text. Filter is applied on load (so the
    // default-selected bag is correct even if the script runs after first
    // paint) and again on every change.
    (() => {
      const select = document.getElementById('bag-select') as HTMLSelectElement | null;
      const scope = document.getElementById('bag-scoped');
      const countEl = document.getElementById('log-shot-count');
      if (!select || !scope) return;

      let counts: Record<string, number> = {};
      try {
        counts = JSON.parse(scope.dataset.shotsByBean ?? '{}');
      } catch { counts = {}; }

      function applyFilter(bean: string) {
        scope!.setAttribute('data-selected-bean', bean);

        // Toggle every data-bean element inside the scope.
        scope!.querySelectorAll<HTMLElement>('[data-bean]').forEach((el) => {
          const match = el.getAttribute('data-bean') === bean;
          if (match) {
            el.style.removeProperty('display');
          } else {
            el.style.display = 'none';
            // If we just hid an open notes-detail row, collapse it so it
            // doesn't pop open silently when the user switches back.
            if (el.classList.contains('notes-detail') && !el.hasAttribute('hidden')) {
              el.setAttribute('hidden', '');
              const prev = el.previousElementSibling;
              prev?.querySelector('.notes-toggle')?.setAttribute('aria-expanded', 'false');
            }
          }
        });

        if (countEl) {
          const n = counts[bean] ?? 0;
          countEl.textContent = `${n} shot${n === 1 ? '' : 's'}`;
        }
      }

      select.addEventListener('change', () => applyFilter(select.value));
      applyFilter(select.value);
    })();
  </script>
</Base>
